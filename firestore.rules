rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{subcollection}/{document} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Stories are readable by anyone authenticated
    match /stories/{storyId} {
      allow read: if request.auth != null;
      allow write: if false; // Only server-side writes
    }

    // Leaderboard is readable by anyone authenticated
    match /leaderboard/{document} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // TTS cache - server-side only (Admin SDK bypasses rules)
    match /tts-cache/{document} {
      allow read, write: if false;
    }

    // Child profiles - any authenticated user who knows the childId can access
    // childId is a random UUID, only discoverable via correct PIN
    match /childProfiles/{childId} {
      allow read, write: if request.auth != null;
      match /dailyActivity/{date} {
        allow read, write: if request.auth != null;
      }
    }

    // Parent-children directory indexed by family code
    match /parentChildren/{familyCode} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
